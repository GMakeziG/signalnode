# Database
DATABASE_URL=postgres://signalnode:signalnode@localhost:5432/signalnode

# JWT signing key — generate with: openssl rand -hex 64
JWT_SECRET=

# Logging — valid values: error, warn, info, debug, trace
RUST_LOG=info

# signalnode-api listen address (default: 0.0.0.0:8080)
PORT=8080

# NotificationChannel config encryption key — generate with: openssl rand -hex 32
# Required when NotificationChannel support is added (Phase 1 slice #5)
CHANNEL_ENCRYPTION_KEY=
